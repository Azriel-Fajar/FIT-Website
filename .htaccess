# FIT Competition 2026 - Clean URL Routing
# Works on localhost (subdirectory) and production (domain root)

Options -MultiViews
RewriteEngine On

# Serve real files and directories directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Redirect .php extensions to clean URLs (localhost subdirectory)
RewriteCond %{HTTP_HOST} ^localhost$ [NC]
RewriteCond %{THE_REQUEST} \s/+FIT%20Website/(.+?)\.php[\s?] [NC]
RewriteRule ^ /FIT%20Website/%1 [R=301,L,NE]

# Redirect .php extensions to clean URLs (production)
RewriteCond %{HTTP_HOST} !^localhost$ [NC]
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# Route clean URLs to PHP files
RewriteRule ^/?$ index.php [L,QSA]
RewriteRule ^about/?$ aboutus.php [L,QSA]
RewriteRule ^winner/?$ winnerpage.php [L,QSA]
RewriteRule ^category/?$ category.php [L,QSA]
RewriteRule ^category-data/?$ category-data.php [L,QSA]
RewriteRule ^category-mobile/?$ category-mobile.php [L,QSA]
RewriteRule ^category-cyber/?$ category-cyber.php [L,QSA]

# Fallback to 404.php for not found pages
ErrorDocument 404 /404.php
